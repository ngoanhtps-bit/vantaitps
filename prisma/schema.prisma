// Logistics App V2 - Prisma schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  hoTen       String
  email       String?  @unique
  sdt         String?
  role        String   @default("thuky")
  active      Boolean  @default(true)
  avatarColor String   @default("emerald")
  lastLogin   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role])
  @@index([active])
}

model RolePermission {
  id        String  @id @default(cuid())
  role      String
  view      String
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, view])
  @@index([role])
}

model NhaCungCap {
  id          String   @id @default(cuid())
  tenDonVi    String
  maNCC       String?  @unique
  sdt         String?
  email       String?
  diaChi      String?
  nguoiLienHe String?
  sdtLienHe   String?
  msThue      String?
  ghiChu      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicles Vehicle[]
  drivers  Driver[]

  @@index([tenDonVi])
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String
  company   String?
  address   String
  city      String
  country   String    @default("Vietnam")
  zipCode   String?
  type      String    @default("business")
  status    String    @default("active")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shipmentsAsSender   Shipment[] @relation("SenderShipments")
  shipmentsAsReceiver Shipment[] @relation("ReceiverShipments")
  invoices            Invoice[]

  @@index([status])
  @@index([city])
}

model Driver {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  phone         String
  licenseNumber String
  licenseExpiry String?
  status        String   @default("available")
  rating        Float    @default(5.0)
  totalDeliveries Int    @default(0)
  totalDistance  Float   @default(0)
  hireDate      String?
  avatarColor   String   @default("emerald")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicleId String? @unique
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  nhaCungCapId String?
  nhaCungCap   NhaCungCap? @relation(fields: [nhaCungCapId], references: [id])

  shipments Shipment[]
  routes    Route[]

  @@index([status])
  @@index([nhaCungCapId])
}

model Vehicle {
  id            String   @id @default(cuid())
  plateNumber   String   @unique
  model         String
  brand         String
  type          String   @default("truck")
  loaiXe        String?
  capacityKg    Float
  fuelType      String   @default("diesel")
  fuelLevel     Float    @default(100)
  mileage       Float    @default(0)
  status        String   @default("active")
  lastMaintenance String?
  nextMaintenance String?
  color         String   @default("slate")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver    Driver?
  shipments Shipment[]
  routes    Route[]

  nhaCungCapId String?
  nhaCungCap   NhaCungCap? @relation(fields: [nhaCungCapId], references: [id])

  @@index([status])
  @@index([type])
  @@index([loaiXe])
  @@index([nhaCungCapId])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String
  city      String
  country   String   @default("Vietnam")
  capacity  Float    @default(1000)
  used      Float    @default(0)
  manager   String?
  phone     String?
  status    String   @default("operational")
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipmentsOrigin      Shipment[] @relation("OriginWarehouse")
  shipmentsDestination Shipment[] @relation("DestinationWarehouse")

  @@index([city])
  @@index([status])
}

model Shipment {
  id              String   @id @default(cuid())
  trackingNumber  String   @unique
  status          String   @default("pending")
  priority        String   @default("standard")
  serviceType     String   @default("standard")

  senderId        String
  sender          Customer @relation("SenderShipments", fields: [senderId], references: [id])
  receiverId      String
  receiver        Customer @relation("ReceiverShipments", fields: [receiverId], references: [id])

  originWarehouseId      String?
  originWarehouse        Warehouse? @relation("OriginWarehouse", fields: [originWarehouseId], references: [id])
  destinationWarehouseId String?
  destinationWarehouse   Warehouse? @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])

  originAddress      String
  originCity         String
  destinationAddress String
  destinationCity    String
  distanceKm         Float     @default(0)

  weightKg   Float
  volumeM3   Float    @default(0)
  pieces     Int      @default(1)
  description String?

  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  cost          Float    @default(0)
  insurance     Float    @default(0)
  currency      String   @default("USD")
  estimatedDelivery String?
  pickedUpAt    String?
  deliveredAt   String?

  currentLat    Float?
  currentLng    Float?
  progress      Float    @default(0)

  notes         String?
  signature     String?

  trailerNumber   String?
  containerNumber String?
  salePerson      String?
  dispatcher      String?
  tripDate        String?
  customerCode    String?

  matHang         String?
  ngayDi          String?
  gioDi           String?
  daGuiBienBan    Boolean  @default(false)
  ghiChu1         String?
  ghiChu2         String?
  ghiChu3         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trackingEvents TrackingEvent[]

  @@index([status])
  @@index([priority])
  @@index([driverId])
  @@index([createdAt])
}

model TrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     String
  location   String?
  lat        Float?
  lng        Float?
  note       String?
  timestamp  DateTime @default(now())

  @@index([shipmentId])
  @@index([timestamp])
}

model Route {
  id          String   @id @default(cuid())
  name        String
  driverId    String?
  driver      Driver?  @relation(fields: [driverId], references: [id])
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  status      String   @default("planned")
  stopsCount  Int      @default(0)
  distanceKm  Float    @default(0)
  durationMin Int      @default(0)
  startedAt   String?
  endedAt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  status        String   @default("draft")
  issueDate     DateTime @default(now())
  dueDate       String
  periodStart   String
  periodEnd     String
  subtotal      Float    @default(0)
  taxRate       Float    @default(0.1)
  taxAmount     Float    @default(0)
  total         Float    @default(0)
  currency      String   @default("USD")
  notes         String?
  paidAt        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
}
