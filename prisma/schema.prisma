// Logistics App V2 — Prisma schema
// SQLite-compatible (no native enums; status fields are String with app-level constants)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  hoTen     String
  email     String?  @unique
  sdt       String?
  role      String   @default("thuky") // "admin" | "dieuxe" | "dieuphoi" | "ketoan" | "thuky"
  active    Boolean  @default(true)
  avatarColor String @default("emerald")
  lastLogin String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([active])
}

// Phân quyền động: role × view × actions
// Admin có thể bật/tắt từng quyền cho từng vai trò
model RolePermission {
  id        String  @id @default(cuid())
  role      String  // "admin" | "dieuxe" | "dieuphoi" | "ketoan" | "thuky"
  view      String  // "dashboard" | "shipments" | "tracking" | ...
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, view])
  @@index([role])
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String
  company   String?
  address   String
  city      String
  country   String    @default("Vietnam")
  zipCode   String?
  type      String    @default("business") // "business" | "individual"
  status    String    @default("active")   // "active" | "inactive" | "vip"
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shipmentsAsSender   Shipment[] @relation("SenderShipments")
  shipmentsAsReceiver Shipment[] @relation("ReceiverShipments")
  invoices            Invoice[]

  @@index([status])
  @@index([city])
}

model NhaCungCap {
  id          String   @id @default(cuid())
  tenDonVi    String
  maNCC       String?  @unique
  sdt         String?
  email       String?
  diaChi      String?
  nguoiLienHe String?
  sdtLienHe   String?
  msThue      String?
  ghiChu      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicles Vehicle[]
  drivers  Driver[]

  @@index([tenDonVi])
}

model Driver {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  phone         String
  licenseNumber String
  licenseExpiry String?
  status        String   @default("available") // "available" | "on_delivery" | "off_duty" | "on_leave"
  rating        Float    @default(5.0)
  totalDeliveries Int    @default(0)
  totalDistance  Float   @default(0) // km
  hireDate      String?
  avatarColor   String   @default("emerald")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicleId String? @unique
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // Liên kết nhà cung cấp xe
  nhaCungCapId String?
  nhaCungCap   NhaCungCap? @relation(fields: [nhaCungCapId], references: [id])

  shipments Shipment[]
  routes    Route[]

  @@index([status])
  @@index([nhaCungCapId])
}

model Vehicle {
  id            String   @id @default(cuid())
  plateNumber   String   @unique
  model         String
  brand         String
  type          String   @default("truck") // "truck" | "van" | "motorbike" | "container"
  loaiXe        String?  // Dòng xe: "CONT 40 RF", "MOOC RÀO", "XE TẢI", v.v.
  capacityKg    Float
  fuelType      String   @default("diesel") // "diesel" | "petrol" | "electric"
  fuelLevel     Float    @default(100) // percentage 0-100
  mileage       Float    @default(0)   // km
  status        String   @default("active") // "active" | "maintenance" | "retired"
  lastMaintenance String?
  nextMaintenance String?
  color         String   @default("slate")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver    Driver?
  shipments Shipment[]
  routes    Route[]

  // Liên kết nhà cung cấp xe
  nhaCungCapId String?
  nhaCungCap   NhaCungCap? @relation(fields: [nhaCungCapId], references: [id])

  @@index([status])
  @@index([type])
  @@index([loaiXe])
  @@index([nhaCungCapId])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String
  city      String
  country   String   @default("Vietnam")
  capacity  Float    @default(1000) // m^3
  used      Float    @default(0)
  manager   String?
  phone     String?
  status    String   @default("operational") // "operational" | "full" | "maintenance" | "closed"
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipmentsOrigin      Shipment[] @relation("OriginWarehouse")
  shipmentsDestination Shipment[] @relation("DestinationWarehouse")

  @@index([city])
  @@index([status])
}

model Shipment {
  id              String   @id @default(cuid())
  trackingNumber  String   @unique
  status          String   @default("pending")
  // "pending" | "picked_up" | "in_transit" | "out_for_delivery" | "delivered" | "delayed" | "cancelled" | "returned"
  priority        String   @default("standard") // "low" | "standard" | "high" | "express"
  serviceType     String   @default("standard") // "standard" | "express" | "same_day" | "freight" | "cold_chain"

  // parties
  senderId        String
  sender          Customer @relation("SenderShipments", fields: [senderId], references: [id])
  receiverId      String
  receiver        Customer @relation("ReceiverShipments", fields: [receiverId], references: [id])

  // routing
  originWarehouseId      String?
  originWarehouse        Warehouse? @relation("OriginWarehouse", fields: [originWarehouseId], references: [id])
  destinationWarehouseId String?
  destinationWarehouse   Warehouse? @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])

  // addresses
  originAddress      String
  originCity         String
  destinationAddress String
  destinationCity    String
  distanceKm         Float     @default(0)

  // cargo
  weightKg   Float
  volumeM3   Float    @default(0)
  pieces     Int      @default(1)
  description String?

  // assignment
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // money & time
  cost          Float    @default(0)
  insurance     Float    @default(0)
  currency      String   @default("USD")
  estimatedDelivery String? // ISO date string
  pickedUpAt    String?
  deliveredAt   String?

  // live tracking
  currentLat    Float?
  currentLng    Float?
  progress      Float    @default(0) // 0-100 percentage

  notes         String?
  signature     String?  // base64 or url

  // Vietnam container trucking fields
  trailerNumber   String?  // Số Mooc
  containerNumber String?  // Số Cont
  salePerson      String?  // SALE
  dispatcher      String?  // DP (điều phối)
  tripDate        String?  // Ngày khởi hành
  customerCode    String?  // Mã khách hàng (vd: GTVD)

  // Bổ sung theo bảng cũ
  matHang         String?  // Mặt hàng: PALET, ĐIỆN TỬ, HÀNG RỜI...
  ngayDi          String?  // Ngày đi (dd/mm/yyyy)
  gioDi           String?  // Giờ đi (HH:mm)
  daGuiBienBan    Boolean  @default(false)  // BB — đã gửi biên bản chưa
  ghiChu1         String?  // Ghi chú 1
  ghiChu2         String?  // Ghi chú 2
  ghiChu3         String?  // Ghi chú 3

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trackingEvents TrackingEvent[]

  @@index([status])
  @@index([priority])
  @@index([driverId])
  @@index([createdAt])
}

model TrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     String
  location   String?
  lat        Float?
  lng        Float?
  note       String?
  timestamp  DateTime @default(now())

  @@index([shipmentId])
  @@index([timestamp])
}

model Route {
  id          String   @id @default(cuid())
  name        String
  driverId    String?
  driver      Driver?  @relation(fields: [driverId], references: [id])
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  status      String   @default("planned") // "planned" | "active" | "completed" | "cancelled"
  stopsCount  Int      @default(0)
  distanceKm  Float    @default(0)
  durationMin Int      @default(0)
  startedAt   String?
  endedAt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  status        String   @default("draft") // "draft" | "sent" | "paid" | "overdue" | "cancelled"
  issueDate     DateTime @default(now())
  dueDate       String
  periodStart   String
  periodEnd     String
  subtotal      Float    @default(0)
  taxRate       Float    @default(0.1)
  taxAmount     Float    @default(0)
  total         Float    @default(0)
  currency      String   @default("USD")
  notes         String?
  paidAt        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
}
